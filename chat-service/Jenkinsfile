pipeline {
    agent any

    environment {
        IMAGE_NAME = "shakilaaulia245/chat-service"
    }

    stages {

        stage('Build Docker Image') {
            steps {
                dir('chat-service') {
                    sh 'docker build -t $IMAGE_NAME .'
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([string(credentialsId: 'dockerhub-token', variable: 'DOCKER_TOKEN')]) {

                    sh 'echo $DOCKER_TOKEN | docker login -u shakilaaulia245 --password-stdin'

                    sh 'docker push $IMAGE_NAME'
                }
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker stop chat-service || true'
                sh 'docker rm chat-service || true'

                sh 'docker run -d --name chat-service -p 8087:8087 $IMAGE_NAME'
            }
        }
    }
}