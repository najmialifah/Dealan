pipeline {
    agent any
    environment {
        
        DOCKER_HUB_USER = 'kelompokdealan' 
        IMAGE_NAME      = 'notification-service'
        IMAGE_TAG       = 'latest'
    }
    stages {
        stage('Checkout Code') {
            steps { echo 'Mengambil kode terbaru dari Git...' }
        }
        stage('Unit Tests') {
            steps {
                dir('notification-service') {
                    echo 'Menjalankan Go Unit Test...'
                    bat 'go test ./...'
                }
            }
        }
        stage('Lint/Vet') {
            steps {
                dir('notification-service') {
                    echo 'Menjalankan Go Vet...'
                    bat 'go vet ./...'
                }
            }
        }
        stage('Build Image') {
            steps {
                dir('notification-service') {
                    bat "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }
        stage('Functional Tests') {
            steps {
                dir('notification-service') {
                    echo 'Menjalankan Functional Test...'
                    bat 'echo "Functional test belum diimplementasikan"'
                }
            }
        }
        stage('Push Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dealan-docker', passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                    bat "echo %PASS%| docker login -u %USER% --password-stdin"
                    bat "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }
        stage('Deploy di kubernetes') {
            steps {
                dir('notification-service') {
                    echo 'Deploying to Kubernetes...'
                    bat 'kubectl apply -f notification-k8s.yaml'
                }
            }
        }
        stage('Verify') {
            steps {
                dir('notification-service') {
                    echo 'Verifying Deployment...'
                    bat 'kubectl rollout status deployment/notification-service-deployment'
                }
            }
        }
    }
}